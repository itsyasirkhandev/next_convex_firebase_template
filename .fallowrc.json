{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/index.{ts,tsx,js,jsx}",
    "src/main.{ts,tsx,js,jsx}"
  ],
  "ignorePatterns": [
    "components/ui/**",
    "convex/_generated/**"
  ],
  "ignoreUnresolvedImports": [
    "./dataModel.js"
  ],
  "ignoreDependencies": [
    "@hookform/resolvers",
    "immer",
    "react-hook-form",
    "convex-test",
    "class-variance-authority",
    "next-themes",
    "radix-ui"
  ],
  "health": {
    "maxCrap": 80,
    "ignore": [
      "convex/_generated/**"
    ]
  },
  "duplicates": {
    "minOccurrences": 3
  },
  "rules": {
    "unused-dependencies": "warn"
  }
}
